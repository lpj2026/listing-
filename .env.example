LINGXING_APP_ID=ak_xxxxxxxx
LINGXING_APP_SECRET=your_secret_here
LINGXING_DEFAULT_STORE_ID=12518
APP_HOST=127.0.0.1
APP_PORT=8001

# 本地开发默认 8001，与补货系统(8000)分开
# 对接领星真实 API 需服务器公网 IP 在白名单，见 README「对接领星真实数据」
PUBLIC_HOST=8.137.177.25
IMAGE_PUBLIC_BASE_URL=http://8.137.177.25/listing
IMAGE_MAX_BYTES=10485760

# 本地开发时，领星 API 403 会自动转发到阿里云（默认 http://8.137.177.25/listing）
# REMOTE_API_BASE=http://8.137.177.25/listing
# DISABLE_REMOTE_PROXY=1

# 可选：配置阿里云 OSS 后，本地图片将直传 OSS（推荐生产环境，HTTPS）
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=your-bucket
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_PREFIX=listing-images/
# OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
